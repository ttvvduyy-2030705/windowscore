      BREAK: 'BREAK',
      MEDIA_NEXT: 'BREAK',
      MEDIA_NEXT_TRACK: 'BREAK',
      MEDIA_FAST_FORWARD: 'BREAK',
      BROWSER_BACK: 'BREAK',
      BROWSER_FORWARD: 'BREAK',
      LAUNCH_MAIL: 'BREAK',
      LAUNCH_MEDIA_SELECT: 'BREAK',
      LAUNCH_APP1: 'BREAK',
      LAUNCH_APP2: 'BREAK',

      WARM: 'WARM_UP',
