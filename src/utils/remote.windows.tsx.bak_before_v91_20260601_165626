      TIMER: 'TIMER',
      TIME: 'TIMER',
      CLOCK: 'TIMER',
      VOLUME_DOWN: 'TIMER',
      VOLUME_MUTE: 'STOP',
      MEDIA_MUTE: 'STOP',
      KEY_T: 'TIMER',
      T: 'TIMER',

      EXTENSION: 'EXTENSION',
      EXTRA_TIME: 'EXTENSION',
      ADD_TIME: 'EXTENSION',
      VOLUME_UP: 'EXTENSION',
      KEY_E: 'EXTENSION',
      E: 'EXTENSION',

      NEWGAME: 'NEW_GAME',
      NEW_GAME: 'NEW_GAME',
      RESET: 'NEW_GAME',
      RESTART: 'NEW_GAME',
      ENTER: 'NEW_GAME',
      RETURN: 'NEW_GAME',
      OK: 'NEW_GAME',
      ACCEPT: 'NEW_GAME',
      SELECT: 'NEW_GAME',
