import {DeviceEventEmitter, NativeModules} from 'react-native';
import {RemoteControlKeys, RemoteControlKeysNative} from 'types/bluetooth';

const DEBUG_REMOTE = true;
const NEW_GAME_HOLD_DURATION_MS = 3000;
const NEW_GAME_RELEASE_GRACE_MS = 900;
const REMOTE_WINDOWS_BUILD = 'v8-break-stop-newgame-crash-fix';

const nativeRemote =
  NativeModules.RemoteControl ??
  NativeModules.RemoteControlModule ??
  NativeModules.AplusRemoteControl;

const debugRemoteLog = (...args: any[]) => {
  if (__DEV__ && DEBUG_REMOTE) {
    console.log(...args);
  }
};

class RemoteControlWindows {
  private static _instance: RemoteControlWindows;
  private _keyEvents: {[key: string]: Function | null} = {};
  private _subscriptions: Array<{remove?: () => void}> = [];
  private _registeredToNative = false;
  private _enabled = false;
  private _newGameHoldTimeout: ReturnType<typeof setTimeout> | null = null;
  private _newGameReleaseCancelTimeout: ReturnType<typeof setTimeout> | null = null;
  private _newGameHoldTriggered = false;
  private _newGameHoldCallback: Function | null = null;
  private _lastBleStatus: any = null;

  private constructor() {
    this.initializeKeySlots();
    // Do not call native remote code while the Windows splash screen is loading.
    // Native listeners are attached lazily when gameplay registers remote keys.
  }

  static get instance() {
    return this._instance || (this._instance = new this());
  }

  private initializeKeySlots = () => {
    const enumKeys = Object.keys(RemoteControlKeys);
    const enumValues = Object.values(RemoteControlKeys);

    [...enumKeys, ...enumValues].forEach(key => {
      const normalizedKey = this.normalizeKeyCode(key);

      if (!(String(key) in this._keyEvents)) {
        this._keyEvents[String(key)] = null;
      }

      if (!(normalizedKey in this._keyEvents)) {
        this._keyEvents[normalizedKey] = null;
      }
    });
  };

  private ensureNativeListener = () => {
    if (this._registeredToNative) {
      return;
    }

    this._subscriptions.push(
      DeviceEventEmitter.addListener('onRemoteKeyDown', this.onRemoteKeyDown),
      DeviceEventEmitter.addListener('onRemoteKeyUp', this.onRemoteKeyUp),
      DeviceEventEmitter.addListener('onRemoteStatus', this.onRemoteStatus),
      DeviceEventEmitter.addListener(
        'onRemoteBluetoothNotification',
        this.onRemoteBluetoothNotification,
      ),
    );

    try {
      debugRemoteLog('[Remote][Windows] init', REMOTE_WINDOWS_BUILD);
      nativeRemote?.startListening?.();
      nativeRemote?.ping?.();
    } catch (error) {
      debugRemoteLog('[Remote][Windows] native listener/ping failed:', error);
    }

    this._registeredToNative = true;
  };

  private normalizeKeyCode = (rawKeyCode: any): string => {
    const raw = String(rawKeyCode ?? '')
      .trim()
      .toUpperCase()
      .replace(/[\s-]+/g, '_');

    const aliasMap: {[key: string]: string} = {
      // Android-compatible codes from billiardsgrade.
      '19': 'UP',
      '20': 'DOWN',
      '21': 'LEFT',
      '22': 'RIGHT',
      '24': 'EXTENSION',
      '25': 'TIMER',
      '29': 'START',
      '30': 'WARM_UP',
      '31': 'STOP',
      '32': 'BREAK',
      '23': 'NEW_GAME',
      '66': 'NEW_GAME',
      '67': 'STOP',
      '68': 'BREAK',
      '82': 'BREAK',
      '85': 'START',
      '86': 'STOP',
      '87': 'BREAK',
      '88': 'WARM_UP',
      '89': 'WARM_UP',
      '90': 'BREAK',
      '126': 'START',
      '127': 'START',
      '160': 'NEW_GAME',

      // Windows virtual-key/media key values for paired Bluetooth remotes.
      '8': 'NEW_GAME',
      '13': 'NEW_GAME',
      '27': 'NEW_GAME',
      '35': 'NEW_GAME',
      '36': 'NEW_GAME',
      '41': 'NEW_GAME',
      '45': 'NEW_GAME',
      '46': 'NEW_GAME',
      '78': 'NEW_GAME',
      '93': 'NEW_GAME',
      '37': 'LEFT',
      '38': 'UP',
      '39': 'RIGHT',
      '40': 'DOWN',
      '65': 'START',
      '69': 'EXTENSION',
      '78': 'NEW_GAME',
      '80': 'START',
      '83': 'STOP',
      '84': 'TIMER',
      '107': 'EXTENSION',
      '109': 'TIMER',
      '174': 'TIMER',
      '175': 'EXTENSION',
      '176': 'BREAK',
      '177': 'WARM_UP',
      '178': 'STOP',
      '179': 'START',
      '181': 'BREAK',
      '182': 'WARM_UP',
      '183': 'STOP',
      '205': 'START',

      LEFT: 'LEFT',
      DPAD_LEFT: 'LEFT',
      ARROW_LEFT: 'LEFT',
      VK_LEFT: 'LEFT',

      RIGHT: 'RIGHT',
      DPAD_RIGHT: 'RIGHT',
      ARROW_RIGHT: 'RIGHT',
      VK_RIGHT: 'RIGHT',

      UP: 'UP',
      DPAD_UP: 'UP',
      ARROW_UP: 'UP',
      VK_UP: 'UP',

      DOWN: 'DOWN',
      DPAD_DOWN: 'DOWN',
      ARROW_DOWN: 'DOWN',
      VK_DOWN: 'DOWN',

      START: 'START',
      PLAY: 'START',
      PAUSE: 'START',
      PLAY_PAUSE: 'START',
      MEDIA_PLAY: 'START',
      MEDIA_PLAY_PAUSE: 'START',
      MEDIA_PAUSE: 'START',
      SPACE: 'START',
      KEY_A: 'START',
      KEY_P: 'START',
      A: 'START',
      P: 'START',

      STOP: 'STOP',
      MEDIA_STOP: 'STOP',
      KEY_S: 'STOP',
      S: 'STOP',
      // Real APLUS remote STOP sends keyboard C on Windows.
      KEY_C: 'STOP',
      C: 'STOP',

      BREAK: 'BREAK',
      MEDIA_NEXT: 'BREAK',
      MEDIA_NEXT_TRACK: 'BREAK',
      MEDIA_FAST_FORWARD: 'BREAK',
      // Real APLUS remote BREAK sends keyboard D on Windows.
      KEY_D: 'BREAK',
      D: 'BREAK',

      WARM: 'WARM_UP',
      WARMUP: 'WARM_UP',
      WARM_UP: 'WARM_UP',
      MEDIA_PREVIOUS: 'WARM_UP',
      MEDIA_PREVIOUS_TRACK: 'WARM_UP',
      MEDIA_REWIND: 'WARM_UP',
      KEY_W: 'WARM_UP',
      W: 'WARM_UP',
      // Real APLUS remote WARM UP sends keyboard B on Windows.
      KEY_B: 'WARM_UP',
      B: 'WARM_UP',

      TIMER: 'TIMER',
      TIME: 'TIMER',
      CLOCK: 'TIMER',
      VOLUME_DOWN: 'TIMER',
      KEY_T: 'TIMER',
      T: 'TIMER',

      EXTENSION: 'EXTENSION',
      EXTRA_TIME: 'EXTENSION',
      ADD_TIME: 'EXTENSION',
      VOLUME_UP: 'EXTENSION',
      KEY_E: 'EXTENSION',
      E: 'EXTENSION',

      NEWGAME: 'NEW_GAME',
      NEW_GAME: 'NEW_GAME',
      RESET: 'NEW_GAME',
      RESTART: 'NEW_GAME',
      ENTER: 'NEW_GAME',
      RETURN: 'NEW_GAME',
      OK: 'NEW_GAME',
      ACCEPT: 'NEW_GAME',
      SELECT: 'NEW_GAME',
      DPAD_CENTER: 'NEW_GAME',
      CENTER: 'NEW_GAME',
      KEY_N: 'NEW_GAME',
      N: 'NEW_GAME',
    };

    return aliasMap[raw] ?? raw;
  };

  private getNormalizedEventKey = (data: RemoteControlKeysNative) => {
    const rawKeyCode = (data as any)?.keyCode;
    const rawKeyCodeInt = (data as any)?.keyCodeInt;
    const rawScanCode = (data as any)?.scanCode;
    const rawResolvedKey =
      (data as any)?.key ??
      (data as any)?.resolvedKey ??
      (data as any)?.code;

    const preferredPhysicalCode =
      rawKeyCode ?? rawKeyCodeInt ?? rawResolvedKey ?? rawScanCode;
    const normalizedFromCode = this.normalizeKeyCode(preferredPhysicalCode);
    const normalizedFromResolved = this.normalizeKeyCode(rawResolvedKey);

    return {
      rawKeyCode,
      rawKeyCodeInt,
      rawScanCode,
      rawResolvedKey,
      preferredPhysicalCode,
      normalizedFromCode,
      normalizedFromResolved,
    };
  };

  private clearNewGameHold = (resetTriggered: boolean) => {
    if (this._newGameHoldTimeout) {
      clearTimeout(this._newGameHoldTimeout);
      this._newGameHoldTimeout = null;
    }

    if (this._newGameReleaseCancelTimeout) {
      clearTimeout(this._newGameReleaseCancelTimeout);
      this._newGameReleaseCancelTimeout = null;
    }

    this._newGameHoldCallback = null;

    if (resetTriggered) {
      this._newGameHoldTriggered = false;
    }
  };

  private scheduleNewGameReleaseCancel = () => {
    if (this._newGameReleaseCancelTimeout) {
      clearTimeout(this._newGameReleaseCancelTimeout);
    }

    this._newGameReleaseCancelTimeout = setTimeout(() => {
      this._newGameReleaseCancelTimeout = null;
      if (!this._newGameHoldTriggered) {
        debugRemoteLog('[Remote][Windows] NEW_GAME released before 3s, cancelled', REMOTE_WINDOWS_BUILD);
        this.clearNewGameHold(true);
      }
    }, NEW_GAME_RELEASE_GRACE_MS);
  };

  private handleNewGameHold = (callback: Function | null, isKeyUp: boolean) => {
    if (isKeyUp) {
      // Some HID remotes send down/up pulses while the physical key is still held.
      // Delay cancel slightly so a 3s hold can still be detected.
      if (this._newGameHoldTriggered) {
        this.clearNewGameHold(true);
      } else {
        this.scheduleNewGameReleaseCancel();
      }
      return;
    }

    if (this._newGameReleaseCancelTimeout) {
      clearTimeout(this._newGameReleaseCancelTimeout);
      this._newGameReleaseCancelTimeout = null;
    }

    if (this._newGameHoldTriggered) {
      return;
    }

    this._newGameHoldCallback = callback;

    if (this._newGameHoldTimeout) {
      return;
    }

    debugRemoteLog('[Remote][Windows] NEW_GAME hold started', REMOTE_WINDOWS_BUILD);

    this._newGameHoldTimeout = setTimeout(() => {
      this._newGameHoldTimeout = null;
      this._newGameHoldTriggered = true;

      debugRemoteLog('[Remote][Windows] NEW_GAME hold 3s triggered', REMOTE_WINDOWS_BUILD);

      const newGameCallback = this._newGameHoldCallback ?? callback;
      if (typeof newGameCallback === 'function') {
        newGameCallback();
      }
    }, NEW_GAME_HOLD_DURATION_MS);
  };

  private getRemoteControlEnumNameForValue = (value: any): string | null => {
    const raw = String(value ?? '');
    const match = Object.entries(RemoteControlKeys).find(
      ([, enumValue]) => String(enumValue) === raw,
    );
    return match?.[0] ?? null;
  };

  private setCallbackForKey = (key: any, callback: Function | null) => {
    if (key === null || key === undefined || key === '') {
      return;
    }

    const raw = String(key);
    const normalized = this.normalizeKeyCode(raw);

    this._keyEvents[raw] = callback;
    this._keyEvents[normalized] = callback;

    const enumNameForRawValue = this.getRemoteControlEnumNameForValue(raw);
    if (enumNameForRawValue) {
      this._keyEvents[enumNameForRawValue] = callback;
      this._keyEvents[this.normalizeKeyCode(enumNameForRawValue)] = callback;
    }

    const enumValueForNormalizedName = (RemoteControlKeys as any)[normalized];
    if (enumValueForNormalizedName !== undefined) {
      this._keyEvents[String(enumValueForNormalizedName)] = callback;
    }
  };

  private getCallbackForEventKey = (eventKey: any) => {
    const candidates = [
      eventKey.normalizedFromCode,
      eventKey.preferredPhysicalCode,
      eventKey.normalizedFromResolved,
      eventKey.rawResolvedKey,
      eventKey.rawKeyCode,
      eventKey.rawKeyCodeInt,
      eventKey.rawScanCode,
    ];

    for (const candidate of candidates) {
      if (candidate === null || candidate === undefined || candidate === '') {
        continue;
      }

      const raw = String(candidate);
      const normalized = this.normalizeKeyCode(raw);
      const enumNameForValue = this.getRemoteControlEnumNameForValue(raw);
      const enumValueForNormalizedName = (RemoteControlKeys as any)[normalized];

      const keysToTry = [
        raw,
        normalized,
        enumNameForValue,
        enumNameForValue ? this.normalizeKeyCode(enumNameForValue) : null,
        enumValueForNormalizedName !== undefined ? String(enumValueForNormalizedName) : null,
      ].filter(Boolean) as string[];

      for (const key of keysToTry) {
        const callback = this._keyEvents[key];
        if (typeof callback === 'function') {
          return callback;
        }
      }
    }

    return null;
  };

  private dispatchRemoteEvent = (
    data: RemoteControlKeysNative,
    isKeyUp: boolean,
  ) => {
    if (!this._enabled) {
      if (isKeyUp) {
        this.clearNewGameHold(true);
      }
      return;
    }

    const repeatCount = Number((data as any)?.repeatCount ?? 0);
    const eventKey = this.getNormalizedEventKey(data);

    debugRemoteLog('[Remote][Windows] incoming:', {
      ...eventKey,
      repeatCount,
      isKeyUp,
      source: (data as any)?.source,
      hex: (data as any)?.hex,
      text: (data as any)?.text,
    });

    const callback = this.getCallbackForEventKey(eventKey);

    if (
      eventKey.normalizedFromCode === 'NEW_GAME' ||
      eventKey.normalizedFromResolved === 'NEW_GAME'
    ) {
      this.handleNewGameHold(callback, isKeyUp);
      return;
    }

    if (isKeyUp || repeatCount > 0) {
      return;
    }

    if (typeof callback === 'function') {
      callback();
      return;
    }

    debugRemoteLog('[Remote][Windows] no callback for key:', eventKey);
  };

  private onRemoteKeyDown = (data: RemoteControlKeysNative) => {
    this.dispatchRemoteEvent(data, false);
  };

  private onRemoteKeyUp = (data: RemoteControlKeysNative) => {
    this.dispatchRemoteEvent(data, true);
  };

  private onRemoteStatus = (data: any) => {
    this._lastBleStatus = data;
    debugRemoteLog('[Remote][Windows] status:', data);
  };

  private onRemoteBluetoothNotification = (data: any) => {
    debugRemoteLog('[Remote][Windows] BLE notification:', data);
  };

  getLastStatus = () => this._lastBleStatus;

  setEnabled = (enabled: boolean) => {
    this.ensureNativeListener();
    this._enabled = !!enabled;

    if (!this._enabled) {
      this.clearNewGameHold(true);
      try {
        nativeRemote?.setEnabled?.(false);
        nativeRemote?.disconnect?.();
      } catch (error) {
        debugRemoteLog('[Remote][Windows] disable failed:', error);
      }
      return;
    }

    try {
      debugRemoteLog('[Remote][Windows] enable', REMOTE_WINDOWS_BUILD);
      nativeRemote?.startListening?.();
      nativeRemote?.setEnabled?.(true);
      // V6: do not start BLE/GATT. The physical APLUS remote is HID on Windows.
      // BLE connect produced Access is denied and allowed volume keys to escape to Windows.
    } catch (error) {
      debugRemoteLog('[Remote][Windows] scan/connect failed:', error);
    }
  };

  scanAndConnect = async () => {
    this.ensureNativeListener();
    this._enabled = true;
    try {
      debugRemoteLog('[Remote][Windows] scanAndConnect redirected to HID only', REMOTE_WINDOWS_BUILD);
      nativeRemote?.startListening?.();
      nativeRemote?.setEnabled?.(true);
      return await nativeRemote?.scanAndConnect?.();
    } catch (error) {
      debugRemoteLog('[Remote][Windows] scanAndConnect failed:', error);
      return undefined;
    }
  };

  disconnect = async () => {
    this._enabled = false;
    this.clearNewGameHold(true);
    try {
      return await nativeRemote?.disconnect?.();
    } catch (error) {
      debugRemoteLog('[Remote][Windows] disconnect failed:', error);
      return undefined;
    }
  };

  isEnabled = () => this._enabled;

  private simulateKeyEvent = (
    keyCode: RemoteControlKeys | string | number,
    isKeyUp: boolean,
  ) => {
    this.ensureNativeListener();

    this.dispatchRemoteEvent(
      {
        keyCode: keyCode as any,
        action: isKeyUp ? 'up' : 'down',
        repeatCount: 0,
        source: 'windows-remote-simulator',
      } as any,
      isKeyUp,
    );
  };

  // Chế độ test không cần Bluetooth: bắn qua đúng luồng xử lý remote của app.
  // Chỉ dùng để kiểm tra phần map nút -> hành động game khi máy không có Bluetooth.
  simulateKey = (keyCode: RemoteControlKeys | string | number) => {
    this.simulateKeyDown(keyCode);
    setTimeout(() => this.simulateKeyUp(keyCode), 120);
  };

  simulateKeyDown = (keyCode: RemoteControlKeys | string | number) => {
    this.simulateKeyEvent(keyCode, false);
  };

  simulateKeyUp = (keyCode: RemoteControlKeys | string | number) => {
    this.simulateKeyEvent(keyCode, true);
  };

  registerKeyEvents = (
    event: RemoteControlKeys | string,
    callback: Function,
  ) => {
    this.ensureNativeListener();
    this.initializeKeySlots();

    this.setCallbackForKey(event, callback);
  };

  registerKeyEvent = (event: RemoteControlKeys | string, callback: Function) => {
    this.registerKeyEvents(event, callback);
  };

  clearKeyEvent = (event: RemoteControlKeys | string) => {
    this.setCallbackForKey(event, null);
  };

  unregisterKeyEvents = (event: RemoteControlKeys | string) => {
    this.clearKeyEvent(event);
  };

  clearAllKeyEvents = () => {
    Object.keys(this._keyEvents).forEach(key => {
      this._keyEvents[key] = null;
    });
  };

  removeAllListeners = () => {
    this._enabled = false;
    this.clearNewGameHold(true);
    this.clearAllKeyEvents();
    this._subscriptions.forEach(subscription => {
      try {
        subscription?.remove?.();
      } catch {}
    });
    this._subscriptions = [];
    this._registeredToNative = false;
    try {
      nativeRemote?.disconnect?.();
    } catch {}
  };
}

export default RemoteControlWindows;
